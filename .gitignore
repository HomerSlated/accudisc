# Build output
build/
*.o
*.so
*.so.*
*.a

# Internal-only tree (git-ignored, never pushed). Holds third-party code
# snapshots, the licensed MMC spec, agent reports, raw research, and the
# Guardian signing keyring. MUST stay ignored — see CLAUDE.md.
private/

# Disc-capture artifacts written at the repo root (real audio data, never
# committable). Root-anchored so the same extensions stay legal as fixtures
# under tests/.
/*.pcm
/*.c2
/*.sub
/*.cdtext
/*.fulltoc
/*.bin
/*.toc
/*.wav

# Third-party / imported reference sources (local-only, see CLAUDE.md)
reference/*
!reference/README.md

# Editors / tooling
.cache/
compile_commands.json
.vscode/
.idea/
backups/
scripts/

# Bindings build artifacts
bindings/rust/target/
bindings/python/dist/
bindings/python/*.egg-info/
__pycache__/

# Session history + remember system (nested git repo, personal config)
.remember/
.claude/remember/
